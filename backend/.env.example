# ============================================
# AI Real-Time Scam Link Detector - Backend
# Environment Configuration
# ============================================

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./scamdetector.db
# DATABASE_URL=postgresql://user:password@localhost:5432/scamdetector

# API Security
API_KEY=your-secret-api-key-change-in-production
RATE_LIMIT=30/minute

# Google Safe Browsing API (Optional)
GOOGLE_SAFE_BROWSING_API_KEY=

# ML Model Path
ML_MODEL_PATH=ml/model/phishing_model.joblib
ML_VECTORIZER_PATH=ml/model/feature_vectorizer.joblib

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
